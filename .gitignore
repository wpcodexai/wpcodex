# AllyWorker — .gitignore

# Live skill files — gitignored so every install keeps its own skills.
# The read-only templates in skills/ ARE committed. Only the live directory
# allyworker-skills/ is excluded.

allyworker-skills/

# PHP sandbox — runtime directory created on plugin activation.
# Contains only temp execution files; never commit.
wp-allyworker-sandbox/

# Composer
/vendor/

# Node / front-end tooling
/node_modules/

# The compiled assets (assets/css/ and assets/js/) ARE committed so the plugin
# works without a build step after installation. Only the tooling artifacts
# below are excluded.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# Operating system files

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# Editor and IDE files

# JetBrains (PhpStorm, WebStorm, etc.)
.idea/

# Vim / Neovim
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# Sublime Text
*.sublime-workspace

# PHP / WordPress development

# WordPress configuration (never commit credentials)
wp-config.php
wp-config-local.php
.env
.env.local
.env.*.local

# WordPress core (if this repo is inside a full WP install)
/wp-admin/
/wp-includes/
/index.php
/wp-*.php
/xmlrpc.php
/license.txt
/readme.html
/wp-content/uploads/
/wp-content/upgrade/
/wp-content/cache/

# PHPUnit
.phpunit.result.cache
.phpunit.cache/

# PHPStan
.phpstan/

# PHP CS Fixer
.php-cs-fixer.cache


# Release ZIP (built by CI, not committed to source)
*.zip
*.tar.gz

# Release info file — updated programmatically, never hand-edited.
# Commit this file; do not add it here.
# release-info.json   ← intentionally NOT gitignored

# Dev mock and local overrides


# Dev mock for Pro features (local development only)
includes/skills/dev-mock.php

# Local wp-config overrides
local-config.php